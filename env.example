<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Leaderboards — GIANNI</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .lb-tabs {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 1.5rem;
      border-bottom: 1px solid var(--border-light);
      padding-bottom: 0;
    }
    .lb-tab {
      padding: 0.6rem 1.25rem;
      border: none;
      background: none;
      color: var(--text-muted);
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
      border-bottom: 2px solid transparent;
      transition: all 0.2s;
      margin-bottom: -1px;
    }
    .lb-tab.active { color: var(--primary-light); border-bottom-color: var(--primary); }
    .lb-tab:hover { color: var(--text); }
    .podium {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 1rem;
      align-items: end;
      margin-bottom: 2rem;
    }
    .podium-item {
      text-align: center;
      padding: 1.5rem 1rem;
      border-radius: 16px;
      background: var(--bg-card2);
    }
    .podium-1 { background: linear-gradient(135deg, rgba(251,191,36,0.15), rgba(245,158,11,0.05)); border: 1px solid rgba(251,191,36,0.3); }
    .podium-2 { background: linear-gradient(135deg, rgba(156,163,175,0.1), transparent); border: 1px solid rgba(156,163,175,0.2); order: -1; }
    .podium-3 { background: linear-gradient(135deg, rgba(217,119,6,0.1), transparent); border: 1px solid rgba(217,119,6,0.2); }
    .podium-avatar {
      width: 52px;
      height: 52px;
      border-radius: 50%;
      margin: 0 auto 0.75rem;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
      font-weight: 800;
    }
    .podium-1 .podium-avatar { background: linear-gradient(135deg, #fbbf24, #d97706); width: 64px; height: 64px; }
    .podium-2 .podium-avatar { background: linear-gradient(135deg, #9ca3af, #6b7280); }
    .podium-3 .podium-avatar { background: linear-gradient(135deg, #d97706, #92400e); }
    .podium-crown { font-size: 1.5rem; }
    .podium-name { font-weight: 700; font-size: 0.875rem; }
    .podium-xp { font-size: 0.8rem; font-weight: 700; margin: 0.3rem 0; }
    .podium-1 .podium-xp { color: #fbbf24; }
    .podium-2 .podium-xp { color: #9ca3af; }
    .podium-3 .podium-xp { color: #d97706; }
    .lb-list { background: var(--bg-card); border-radius: 16px; overflow: hidden; }
    .lb-row {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1rem 1.25rem;
      border-bottom: 1px solid rgba(255,255,255,0.04);
      transition: background 0.2s;
    }
    .lb-row:hover { background: var(--bg-card2); }
    .lb-rank-num { font-weight: 800; min-width: 36px; font-size: 0.9rem; }
    .lb-avatar {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--primary), var(--primary-dark));
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.875rem;
      font-weight: 700;
      color: white;
    }
    .lb-name { flex: 1; font-size: 0.875rem; font-weight: 600; }
    .lb-sub { font-size: 0.75rem; color: var(--text-muted); }
    .lb-xp { font-weight: 700; font-size: 0.875rem; color: var(--primary-light); }
    .level-pill {
      background: rgba(99,102,241,0.15);
      color: #818cf8;
      padding: 0.2rem 0.6rem;
      border-radius: 50px;
      font-size: 0.75rem;
      font-weight: 700;
    }
  </style>
</head>
<body>
  <nav class="navbar">
    <a href="/" class="navbar-brand">GIANNI</a>
    <ul class="navbar-nav">
      <li><a href="/">Home</a></li>
      <li><a href="/games">Games</a></li>
      <li><a href="/music">Music</a></li>
      <li><a href="/servers">Servers</a></li>
      <li><a href="/leaderboards">Leaderboards</a></li>
      <li id="nav-botpanel" style="display:none;"><a href="/bot-panel" class="btn-bot-panel">Bot Panel</a></li>
    </ul>
    <div class="navbar-user" id="navbar-user">
      <div class="spinner" style="width:24px;height:24px;border-width:2px;"></div>
    </div>
  </nav>

  <div class="page">
    <div class="container section">
      <h2 style="font-size:2rem;font-weight:900;text-align:center;margin-bottom:2rem;color:#fbbf24;">🏆 GIANNI Leaderboards</h2>

      <!-- Tabs -->
      <div class="lb-tabs">
        <button class="lb-tab active" onclick="switchTab('overall', this)">Overall</button>
        <button class="lb-tab" onclick="switchTab('weekly', this)">This Week</button>
        <button class="lb-tab" onclick="switchTab('games', this)">Games</button>
        <button class="lb-tab" onclick="switchTab('music', this)">Music</button>
      </div>

      <!-- Loading -->
      <div id="lb-loading" style="text-align:center;padding:3rem;"><div class="spinner" style="margin:0 auto;"></div></div>
      <div id="lb-content" style="display:none;">
        <!-- Podium -->
        <div class="podium" id="podium"></div>
        <!-- Rest of list -->
        <div class="lb-list" id="lb-list"></div>
      </div>
    </div>
  </div>

  <script src="/js/main.js"></script>
  <script>
    let leaderboardData = [];

    function switchTab(tab, el) {
      document.querySelectorAll('.lb-tab').forEach(t => t.classList.remove('active'));
      el.classList.add('active');
      renderLeaderboard(leaderboardData);
    }

    function renderLeaderboard(data) {
      document.getElementById('lb-loading').style.display = 'none';
      document.getElementById('lb-content').style.display = 'block';

      const [first, second, third, ...rest] = data;

      // Podium
      document.getElementById('podium').innerHTML = `
        <div class="podium-item podium-2">
          <div class="podium-avatar">${second?.username?.charAt(0) || '?'}</div>
          <div style="font-size:1.5rem;">🥈</div>
          <div class="podium-name">${second?.username || 'N/A'}</div>
          <div class="podium-xp">${formatNumber(second?.xp || 0)} XP</div>
          <span class="level-pill">Lv.${second?.level || 0}</span>
        </div>
        <div class="podium-item podium-1">
          <div class="podium-crown">👑</div>
          <div class="podium-avatar">${first?.username?.charAt(0) || '?'}</div>
          <div style="font-size:1.5rem;">🥇</div>
          <div class="podium-name">${first?.username || 'N/A'}</div>
          <div class="podium-xp">${formatNumber(first?.xp || 0)} XP</div>
          <span class="level-pill">Lv.${first?.level || 0}</span>
        </div>
        <div class="podium-item podium-3">
          <div class="podium-avatar">${third?.username?.charAt(0) || '?'}</div>
          <div style="font-size:1.5rem;">🥉</div>
          <div class="podium-name">${third?.username || 'N/A'}</div>
          <div class="podium-xp">${formatNumber(third?.xp || 0)} XP</div>
          <span class="level-pill">Lv.${third?.level || 0}</span>
        </div>
      `;

      // List
      document.getElementById('lb-list').innerHTML = rest.map(player => `
        <div class="lb-row">
          <span class="lb-rank-num" style="color:var(--text-muted);">#${player.rank}</span>
          <div class="lb-avatar">${player.username.charAt(0)}</div>
          <div class="lb-name">
            ${player.username}
            <div class="lb-sub">${formatNumber(player.xp)} XP</div>
          </div>
          <span class="level-pill">Lv.${player.level}</span>
          <span class="${player.trend === 'up' ? 'trend-up' : 'trend-down'}">${player.trend === 'up' ? '▲' : '▼'}</span>
          <span class="lb-xp">${formatNumber(player.xp)}</span>
        </div>
      `).join('');
    }

    async function init() {
      const user = await initUser();
      if (!user) { window.location.href = '/login'; return; }
      try {
        const res = await fetch('/api/leaderboard');
        leaderboardData = await res.json();
        renderLeaderboard(leaderboardData);
      } catch {
        document.getElementById('lb-loading').innerHTML = '<p style="color:var(--text-muted)">Failed to load leaderboard.</p>';
      }
    }
    init();
  </script>
</body>
</html>
